# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Razorpay
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Razorpay Subscription Plan IDs (create in Razorpay dashboard)
RAZORPAY_PLAN_ID_PRO_INR=plan_...
RAZORPAY_PLAN_ID_PRO_USD=plan_...
RAZORPAY_PLAN_ID_ELITE_INR=plan_...
RAZORPAY_PLAN_ID_ELITE_USD=plan_...
RAZORPAY_PLAN_ID_BYOK_INR=plan_...
RAZORPAY_PLAN_ID_BYOK_USD=plan_...

# BYOK Encryption (generate a strong random string)
BYOK_ENCRYPTION_SECRET=your-32-char-secret-here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
